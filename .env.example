# Dart Dashboard – Konfiguration
# Diese Datei in das gleiche Verzeichnis wie docker-compose.yml legen.

# IP-Adresse des Unraid/Docker-Servers (LAN-IP, damit der Fire Stick die richtige URL bekommt)
# Ohne diese Angabe wird die Docker-interne IP erkannt (falsch!)
SERVER_IP=192.168.8.100

# IP-Adresse des Amazon Fire Sticks
FIRESTICK_IP=192.168.8.177

# Datenpfad für persistente Einstellungen
# Auf Unraid empfohlen:
DATA_PATH=/mnt/user/appdata/dart-dashboard/data
# Lokal (PC/Dev) einfach auskommentieren → fällt auf ./data zurück

# ADB-Keys Pfad (WICHTIG: persistieren damit der Fire TV nicht bei jedem Neustart erneut bestätigen muss)
# Einmal bestätigen → nie wieder den USB-Debug-Dialog sehen
ADB_KEYS_PATH=/mnt/user/appdata/dart-dashboard/adb-keys

# Fire-TV/ADB Funktionen aktivieren (muss true sein, damit Fire-TV Start funktioniert)
FIRE_FEATURES_ENABLED=true

# Trennung: false = dart-dashboard als reiner Dart-Service (empfohlen)
# true = alter Hub/Admin im dart-dashboard wieder aktiv
DART_HUB_ENABLED=false

# Optional: expliziter ADB-Binary-Pfad (auf Linux/Raspi meist nicht nötig, Standard ist "adb")
# ADB_PATH=/usr/bin/adb

# -----------------------------
# SQL-Storage (neu)
# -----------------------------
# Standard: lokale SQLite-Datei
DB_CLIENT=sqlite
DB_SQLITE_FILE=./data/dashboard.db

# Externe SQL-DB (optional) - dann liegen die Daten nicht auf dem Raspi
# DB_CLIENT=postgres
# DB_URL=postgres://user:pass@db-host:5432/dart_dashboard

# Alternative: MySQL
# DB_CLIENT=mysql
# DB_URL=mysql://user:pass@db-host:3306/dart_dashboard

# Optional fuer externe TLS-Verbindungen
# DB_SSL=true
